<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}" />
  {% if robotsNoAi %}
  <meta name="robots" content="noai, noimageai, noindex" />
  {% endif %}
  <link rel="icon" href="/assets/svg/logo-mark.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/assets/css/style.css" />
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}" />
  <meta property="og:description" content="{{ description or site.description }}" />
  <meta property="og:type" content="website" />
</head>
<body class="{% if noScroll %}no-scroll-page{% endif %} font-body">
  {% include "components/nav.njk" %}

  <main class="{% if noScroll %}flex-1 flex flex-col pt-16 sm:pt-20 min-h-0{% else %}pt-20 sm:pt-24{% endif %}">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}

  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    (function () {
      if (!window.netlifyIdentity) return;
      window.netlifyIdentity.on("init", function (user) {
        if (!user) {
          window.netlifyIdentity.on("login", function () {
            document.location.href = "/admin/";
          });
        }
      });
      /* 招待・パスワード再設定メールのリンク（#invite_token= / #recovery_token=）を
         どのページで開いても、自動的に設定モーダルを表示する */
      if (/invite_token=|recovery_token=|confirmation_token=/.test(window.location.hash)) {
        window.netlifyIdentity.open();
      }
    })();
  </script>
</body>
</html>
